OPENROUTER_API_KEY=
APIFY_TOKEN=
AR_GEOREF_BASE_URL=https://apis.datos.gob.ar/georef/api
AR_CRIME_INGEST_ENABLE_MEDIA_SCRAPERS=false
AR_CRIME_RATE_LIMIT_RPS=0.5
AR_CRIME_SCHEDULER_ENABLED=true

# Database Connection (Neon, Vercel Postgres, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Secret for invoking the Vercel/Netlify Cron ingest endpoint
CRON_SECRET=super_secret_cron_token
